# Local dev — mirrors .env.example
# shellcheck disable=SC2034

SERVICE_NAME=identity
DB_NAME=identity

# DATABASE_URL is injected by devenv.nix at shell-enter time:
#   postgres:///${DB_NAME}?host=${DEVENV_RUNTIME}/postgres
# (Unix socket to the local Postgres on port 5433.)
# Do not hardcode it here — $DEVENV_RUNTIME differs per checkout.

# --- RS256 keypair ---------------------------------------------------------
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# --- JWT claim defaults ----------------------------------------------------
JWT_ISSUER=identity
JWT_AUDIENCE=ft-transcendence
JWT_KID=identity-main

# --- TTLs ------------------------------------------------------------------
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=14

# --- Security --------------------------------------------------------------
BCRYPT_COST=12
