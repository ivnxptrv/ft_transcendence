# Identity service — copy to .env and fill in values
# shellcheck disable=SC2034

SERVICE_NAME=identity
DB_NAME=identity

# DATABASE_URL is provided by devenv.nix in dev and by docker-compose in prod.
# Example (prod): DATABASE_URL=postgresql://identity_user:pw@postgres:5432/identity

# --- RS256 keypair ---------------------------------------------------------
# One-time bootstrap before first run:
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# uvicorn refuses to start if either PEM is missing (see app/main.py lifespan).
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# --- JWT claim defaults ----------------------------------------------------
JWT_ISSUER=identity
JWT_AUDIENCE=ft-transcendence
JWT_KID=identity-main

# --- TTLs ------------------------------------------------------------------
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=14

# --- Security --------------------------------------------------------------
BCRYPT_COST=12
